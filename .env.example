# OANDA v20 demo
OANDA_API_TOKEN=your_oanda_api_token_here
OANDA_ACCOUNT_ID=101-xxx-xxxxxxxx-001
OANDA_ENVIRONMENT=practice   # practice = demo; live = real money

# Finnhub
FINNHUB_API_KEY=your_finnhub_api_key_here

# Google Gemini
GEMINI_API_KEY=your_gemini_api_key_here

# Telegram alerts (optional — leave blank to disable)
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_numeric_chat_id_here

# Optional overrides
LOG_LEVEL=INFO               # DEBUG for verbose output
FLASK_PORT=5000
